# Tina client ID from your TinaCloud project's Overview tab.
PUBLIC_TINA_CLIENT_ID=your_tina_client_id

# Optional alias if you prefer a non-public-looking variable name in CI.
# TINA_CLIENT_ID=your_tina_client_id

# Tina read-only token from your TinaCloud project's Tokens tab.
TINA_TOKEN=your_tina_token
