{
  // Cloudflare Workers configuration for shafii-madhhab-blog
  // The worker serves the static Astro build output in ./dist, including Tina's admin.
  "name": "shafii-madhhab-blog",
  "main": "oauth-worker.js",
  "compatibility_date": "2024-09-23",
  "assets": {
    // Points to Astro's build output directory
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
