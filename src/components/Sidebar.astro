---
import { getCollection } from "astro:content";
import getUniqueTags from "@utils/getUniqueTags";
import { slugifyStr } from "@utils/slugify";

const posts = await getCollection("posts");
const tags = getUniqueTags(posts);
---

<aside class="sidebar">
  <!-- Tag cloud -->
  <div class="widget">
    <h3 class="widget-title">Themen</h3>
    <div class="tag-cloud">
      {
        tags.map(tag => (
          <a href={`/tags/${slugifyStr(tag)}`} class="tag-pill">
            {tag}
          </a>
        ))
      }
    </div>
  </div>
</aside>

<style>
  .sidebar {
    @apply flex flex-col gap-6;
  }

  .widget {
    @apply rounded-lg border border-skin-line bg-skin-card p-5;
  }

  .widget-title {
    @apply mb-3 border-b border-skin-line pb-2 text-lg font-semibold
      tracking-wide text-skin-accent;
  }

  /* Tag cloud */
  .tag-cloud {
    @apply flex flex-wrap gap-2;
  }

  .tag-pill {
    @apply rounded-full border border-skin-line bg-skin-fill px-3 py-1
      text-sm text-skin-base transition-colors
      hover:border-skin-accent hover:bg-skin-accent hover:text-skin-inverted;
  }
</style>
